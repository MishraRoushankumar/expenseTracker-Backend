{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "esModuleInterop": true,

    "sourceMap": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "express"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
